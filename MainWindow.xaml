<Window x:Class="DataStock.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DataStock.Windows"
        xmlns:models="clr-namespace:DataStock.Windows.Models"
        xmlns:vm="clr-namespace:DataStock.Windows.ViewModels"
        Title="DataStock"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Icon="Resources/AppIcon.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <vm:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <vm:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True" />
        <vm:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <vm:CountToVisibilityConverter x:Key="InverseCountToVisibilityConverter" Invert="True" />
        <vm:EnumVisibilityConverter x:Key="EnumVisibilityConverter" />
        <vm:RunModeCheckedConverter x:Key="RunModeCheckedConverter" />
        <vm:LogLevelBrushConverter x:Key="LogLevelBrushConverter" />
        <vm:ExclusionGlyphConverter x:Key="ExclusionGlyphConverter" />

        <DataTemplate DataType="{x:Type models:SyncDestination}">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0"
                          Margin="0,0,10,0"
                          VerticalAlignment="Center"
                          IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Column="1"
                         Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="{Binding Path}" />
                <Button Grid.Column="2"
                        Style="{StaticResource IconButton}"
                        Margin="8,0,0,0"
                        Command="{Binding DataContext.BrowseDestinationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        ToolTip="{local:Loc ChooseFolder}">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8B7;" />
                </Button>
                <Button Grid.Column="3"
                        Style="{StaticResource IconButton}"
                        Margin="8,0,0,0"
                        Command="{Binding DataContext.RemoveDestinationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        ToolTip="{local:Loc Remove}">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE74D;" />
                </Button>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:SyncExclusion}">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Style="{StaticResource IconText}"
                           Margin="0,0,10,0"
                           Foreground="{StaticResource AccentBrush}">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource ExclusionGlyphConverter}">
                            <Binding Path="RelativePath" />
                            <Binding Path="DataContext.SelectedJob.SourcePath" RelativeSource="{RelativeSource AncestorType=Window}" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{Binding RelativePath}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding RelativePath}" />
                <Button Grid.Column="2"
                        Style="{StaticResource IconButton}"
                        Margin="8,0,0,0"
                        Click="OpenButtonContextMenu"
                        CommandParameter="{Binding}"
                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                        ToolTip="{local:Loc Edit}">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{local:Loc ChooseFolder}"
                                      Command="{Binding PlacementTarget.Tag.EditFolderExclusionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="{local:Loc ChooseFile}"
                                      Command="{Binding PlacementTarget.Tag.EditFileExclusionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE70F;" />
                </Button>
                <Button Grid.Column="3"
                        Style="{StaticResource IconButton}"
                        Margin="8,0,0,0"
                        Command="{Binding DataContext.RemoveExclusionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        ToolTip="{local:Loc Remove}">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE74D;" />
                </Button>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:ClockTime}">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ComboBox Width="76"
                          ItemsSource="{Binding DataContext.Hours, RelativeSource={RelativeSource AncestorType=Window}}"
                          SelectedItem="{Binding Hour, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text=":"
                           Margin="8,0"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}" />
                <ComboBox Width="76"
                          ItemsSource="{Binding DataContext.Minutes, RelativeSource={RelativeSource AncestorType=Window}}"
                          SelectedItem="{Binding Minute, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Style="{StaticResource IconButton}"
                        Margin="8,0,0,0"
                        Command="{Binding DataContext.RemoveTimeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        ToolTip="{local:Loc Remove}">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE74D;" />
                </Button>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="240" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" MinWidth="620" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <Border DockPanel.Dock="Top"
                    Padding="18,16,18,12"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Width="32"
                           Height="32"
                           Source="Resources/DataStockIcon.png"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="DataStock" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="{local:Loc ParentFolders}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Bottom"
                    Padding="14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Background="{StaticResource SidebarBackgroundBrush}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Margin="0,0,5,0"
                                Command="{Binding AddJobCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE710;" />
                                <TextBlock Margin="7,0,0,0" Text="{local:Loc Add}" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1"
                                Margin="5,0,0,0"
                                Command="{Binding DeleteSelectedJobCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE74D;" />
                                <TextBlock Margin="7,0,0,0" Text="{local:Loc Delete}" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <CheckBox Content="{local:Loc LaunchAtStartup}"
                              IsChecked="{Binding LaunchAtStartup, Mode=TwoWay}"
                              FontWeight="SemiBold" />
                    <TextBlock Margin="22,4,0,10"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="{Binding StartupStatusText}" />

                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc Language}" />
                            <ComboBox Grid.Row="1"
                                      Margin="0,6,0,12"
                                      ItemsSource="{Binding LanguageOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay}" />
                            <Button Grid.Row="2" Command="{Binding QuitCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE7E8;" />
                                    <TextBlock Margin="7,0,0,0" Text="{local:Loc AppQuit}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <ListBox ItemsSource="{Binding Store.Jobs}"
                     SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Margin" Value="10,4" />
                        <Setter Property="Padding" Value="9,8" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <Border x:Name="Chrome"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ContentPresenter Margin="{TemplateBinding Padding}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Chrome" Property="Background" Value="#EAF3FF" />
                                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#B8D8FF" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chrome" Property="Background" Value="#F0F0F0" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:SyncJob}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource IconText}"
                                       FontSize="18"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="&#xE8B7;" />
                            <StackPanel Grid.Column="1" Margin="10,0,8,0">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding DisplayName}" />
                                <TextBlock Text="{Binding ScheduleSummary}"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding ScheduleSummary}" />
                            </StackPanel>
                            <TextBlock x:Name="StatusGlyph"
                                       Grid.Column="2"
                                       Style="{StaticResource IconText}"
                                       Text="{Binding StatusGlyph}"
                                       Foreground="{StaticResource WarningBrush}"
                                       ToolTip="{Binding StatusText}" />
                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        Margin="8,0,0,0">
                                <Button Style="{StaticResource IconButton}"
                                        Width="28"
                                        MinHeight="26"
                                        Command="{Binding DataContext.MoveJobUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{local:Loc MoveUp}">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE70E;" />
                                </Button>
                                <Button Style="{StaticResource IconButton}"
                                        Width="28"
                                        MinHeight="26"
                                        Margin="4,0,0,0"
                                        Command="{Binding DataContext.MoveJobDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{local:Loc MoveDown}">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE70D;" />
                                </Button>
                            </StackPanel>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding CanRun}" Value="True">
                                <Setter TargetName="StatusGlyph" Property="Foreground" Value="{StaticResource SuccessBrush}" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <Border Grid.Column="1" Background="{StaticResource BorderBrush}" />

        <Grid Grid.Column="2">
            <Grid Visibility="{Binding SelectedJob, Converter={StaticResource InverseNullToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Width="92"
                           Height="92"
                           Source="Resources/DataStockIcon.png"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Margin="0,18,0,10"
                               Text="{local:Loc NoBackup}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddJobCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE710;" />
                            <TextBlock Margin="8,0,0,0" Text="{local:Loc CreateBackup}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <ScrollViewer Visibility="{Binding SelectedJob, Converter={StaticResource NullToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="900" Margin="28" HorizontalAlignment="Left">
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image Width="56"
                               Height="56"
                               Source="Resources/DataStockIcon.png"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <StackPanel Grid.Column="1" Margin="14,0,20,0" VerticalAlignment="Center">
                            <TextBox Text="{Binding SelectedJob.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="24"
                                     FontWeight="SemiBold"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="0"
                                     ToolTip="{local:Loc Name}" />
                            <TextBlock Text="{Binding SelectedJob.StatusText}"
                                       Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,10,0"
                                    Command="{Binding RunSelectedSynchronizeCommand}"
                                    IsEnabled="{Binding SelectedJob.CanStartRun}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE768;" />
                                    <TextBlock Margin="8,0,0,0" Text="{local:Loc Sync}" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunSelectedTransferCommand}"
                                    IsEnabled="{Binding SelectedJob.CanStartRun}"
                                    ToolTip="{local:Loc TransferHelp}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE72D;" />
                                    <TextBlock Margin="8,0,0,0" Text="{local:Loc Transfer}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc ParentFolder}" Margin="0,0,0,8" />
                    <Border Style="{StaticResource SectionCard}" Margin="0,0,0,18">
                        <StackPanel>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc Source}" />
                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             MinHeight="32"
                                             Text="{Binding SelectedJob.SourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="{Binding SelectedJob.SourcePath}" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource IconButton}"
                                            Width="36"
                                            Height="32"
                                            MinHeight="32"
                                            Margin="8,0,0,0"
                                            Click="OpenButtonContextMenu"
                                            ToolTip="{local:Loc ChooseSource}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{local:Loc ChooseFolder}"
                                                          Command="{Binding PlacementTarget.DataContext.BrowseSourceFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="{local:Loc ChooseFile}"
                                                          Command="{Binding PlacementTarget.DataContext.BrowseSourceFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE8B7;" />
                                    </Button>
                                </Grid>
                                <TextBlock Grid.Row="2"
                                           Margin="0,6,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="{Binding SelectedJob.SourceKindLabel}" />
                            </Grid>

                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Margin="0,16,0,12" />

                            <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc ExcludedItems}" />
                            <TextBlock Margin="0,8,0,10"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{local:Loc NoExcludedItem}"
                                       Visibility="{Binding SelectedJob.Exclusions.Count, Converter={StaticResource InverseCountToVisibilityConverter}}" />
                            <ItemsControl Margin="0,8,0,0"
                                          ItemsSource="{Binding SelectedJob.Exclusions}"
                                          Visibility="{Binding SelectedJob.Exclusions.Count, Converter={StaticResource CountToVisibilityConverter}}" />
                            <Button HorizontalAlignment="Left"
                                    Margin="0,4,0,0"
                                    Click="OpenButtonContextMenu">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{local:Loc AddFolderExclusion}"
                                                  Command="{Binding PlacementTarget.DataContext.AddFolderExclusionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="{local:Loc AddFileExclusion}"
                                                  Command="{Binding PlacementTarget.DataContext.AddFileExclusionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE710;" />
                                    <TextBlock Margin="7,0,0,0" Text="{local:Loc AddExclusion}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc ChildDirectories}" Margin="0,0,0,8" />
                    <Border Style="{StaticResource SectionCard}" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{local:Loc NoChildDirectory}"
                                       Visibility="{Binding SelectedJob.Destinations.Count, Converter={StaticResource InverseCountToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding SelectedJob.Destinations}" />
                            <Button HorizontalAlignment="Left"
                                    Margin="0,6,0,0"
                                    Command="{Binding AddDestinationCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE710;" />
                                    <TextBlock Margin="7,0,0,0" Text="{local:Loc AddDirectory}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc Automation}" Margin="0,0,0,8" />
                    <Border Style="{StaticResource SectionCard}" Margin="0,0,0,18">
                        <StackPanel>
                            <CheckBox Content="{local:Loc Automation}"
                                      IsChecked="{Binding SelectedJob.Schedule.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      FontWeight="SemiBold" />

                            <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc AutomationMode}" Margin="0,16,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Style="{StaticResource SegmentedToggle}"
                                             GroupName="RunMode"
                                             Content="{local:Loc FullSynchronization}"
                                             IsChecked="{Binding SelectedJob.Schedule.RunMode, Mode=TwoWay, Converter={StaticResource RunModeCheckedConverter}, ConverterParameter=Synchronize}" />
                                <RadioButton Style="{StaticResource SegmentedToggle}"
                                             GroupName="RunMode"
                                             Margin="8,0,0,0"
                                             Content="{local:Loc SimpleTransfer}"
                                             IsChecked="{Binding SelectedJob.Schedule.RunMode, Mode=TwoWay, Converter={StaticResource RunModeCheckedConverter}, ConverterParameter=Transfer}" />
                            </StackPanel>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CaptionText}"
                                           Text="{local:Loc Frequency}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ScheduleKindOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedJob.Schedule.Kind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding SelectedJob.Schedule.Kind, Converter={StaticResource EnumVisibilityConverter}, ConverterParameter=Weekly}">
                                <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc Weekdays}" />
                                <WrapPanel Margin="0,8,0,0">
                                    <ToggleButton Style="{StaticResource DayToggle}" Margin="0,0,6,6" Content="{local:Loc WeekdayMondayShort}" IsChecked="{Binding IsMondaySelected, Mode=TwoWay}" />
                                    <ToggleButton Style="{StaticResource DayToggle}" Margin="0,0,6,6" Content="{local:Loc WeekdayTuesdayShort}" IsChecked="{Binding IsTuesdaySelected, Mode=TwoWay}" />
                                    <ToggleButton Style="{StaticResource DayToggle}" Margin="0,0,6,6" Content="{local:Loc WeekdayWednesdayShort}" IsChecked="{Binding IsWednesdaySelected, Mode=TwoWay}" />
                                    <ToggleButton Style="{StaticResource DayToggle}" Margin="0,0,6,6" Content="{local:Loc WeekdayThursdayShort}" IsChecked="{Binding IsThursdaySelected, Mode=TwoWay}" />
                                    <ToggleButton Style="{StaticResource DayToggle}" Margin="0,0,6,6" Content="{local:Loc WeekdayFridayShort}" IsChecked="{Binding IsFridaySelected, Mode=TwoWay}" />
                                    <ToggleButton Style="{StaticResource DayToggle}" Margin="0,0,6,6" Content="{local:Loc WeekdaySaturdayShort}" IsChecked="{Binding IsSaturdaySelected, Mode=TwoWay}" />
                                    <ToggleButton Style="{StaticResource DayToggle}" Margin="0,0,6,6" Content="{local:Loc WeekdaySundayShort}" IsChecked="{Binding IsSundaySelected, Mode=TwoWay}" />
                                </WrapPanel>
                            </StackPanel>

                            <Grid Margin="0,16,0,0"
                                  Visibility="{Binding SelectedJob.Schedule.Kind, Converter={StaticResource EnumVisibilityConverter}, ConverterParameter=Monthly}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc DayOfMonth}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding MonthDays}"
                                          SelectedItem="{Binding SelectedJob.Schedule.DayOfMonth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding SelectedJob.Schedule.Kind, Converter={StaticResource EnumVisibilityConverter}, ConverterParameter=EveryNDays}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc Interval}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding SelectedJob.Schedule.IntervalDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Column="2"
                                              Margin="8,0,0,0"
                                              ItemsSource="{Binding IntervalUnitOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedJob.Schedule.IntervalUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <TextBlock Margin="170,8,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Text="{local:Loc ShorterMonthsUseLastDay}" />
                            </StackPanel>

                            <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc Hours}" Margin="0,16,0,8" />
                            <ItemsControl ItemsSource="{Binding SelectedJob.Schedule.Times}" />
                            <Button HorizontalAlignment="Left"
                                    Command="{Binding AddTimeCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE710;" />
                                    <TextBlock Margin="7,0,0,0" Text="{local:Loc AddTime}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc Status}" Margin="0,0,0,8" />
                    <Border Style="{StaticResource SectionCard}" Margin="0,0,0,18">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}"
                                           Text="{Binding SelectedJob.StatusGlyph}"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="{Binding SelectedJob.StatusText}" />
                            </StackPanel>
                            <Grid Margin="0,10,0,0" Visibility="{Binding SelectedJob.LastRunDate, Converter={StaticResource NullToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="{local:Loc LastSync}" />
                                <TextBlock Grid.Column="1" Text="{Binding SelectedJob.LastRunDateDisplay}" />
                            </Grid>
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{Binding SelectedJob.LastRunMessage}" />
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc Log}" Margin="0,0,0,8" />
                    <Border Style="{StaticResource SectionCard}" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{local:Loc NoEvent}"
                                       Visibility="{Binding Store.Logs.Count, Converter={StaticResource InverseCountToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding Store.Logs}"
                                          Visibility="{Binding Store.Logs.Count, Converter={StaticResource CountToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:SyncLogEntry}">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Style="{StaticResource IconText}"
                                                       Text="{Binding Glyph}"
                                                       Foreground="{Binding Level, Converter={StaticResource LogLevelBrushConverter}}" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0"
                                                       Text="{Binding Message}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Message}" />
                                            <TextBlock Grid.Column="2"
                                                       FontSize="12"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Text="{Binding TimeDisplay}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource CaptionText}" Text="{local:Loc History}" Margin="0,0,0,8" />
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{local:Loc NoSync}"
                                       Visibility="{Binding SelectedJob.History.Count, Converter={StaticResource InverseCountToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding SelectedJob.History}"
                                          Visibility="{Binding SelectedJob.History.Count, Converter={StaticResource CountToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:SyncHistoryEntry}">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Style="{StaticResource IconText}"
                                                       Text="&#xE73E;"
                                                       Foreground="{StaticResource SuccessBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0"
                                                       Text="{Binding DateDisplay}" />
                                            <TextBlock Grid.Column="2"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       Text="{Binding ResultText}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
